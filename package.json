{
  "name": "webitel-sdk",
  "version": "26.04.8",
  "description": "A library written in TypeScript",
  "keywords": [],
  "type": "commonjs",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/webitel/webitel_sdk.git"
  },
  "author": "navrotskyj <navrotskyj@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/sync-version.js && tsdown && npm run build:types && node scripts/copy",
    "build:types": "tsc -p tsconfig.build.json || echo '⚠ tsc reported type errors (auto-generated API code under modern @types/node) — declarations were still emitted; run `npm run api` to regenerate'",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "docs": "typedoc --plugin typedoc-github-theme --exclude \"**/src/**/__tests__/*.*\" --out docs src/socket",
    "test": "jest -c ./config/jest.config.js",
    "test:watch": "npm t -- --watch",
    "test:ci": "npm t -- --ci",
    "validate-js": "tsc -p ./config && tsc -p ./scripts",
    "verify": "npm run validate-js && npm run check && npm run test:ci",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format:fix": "node scripts/sync-version.js && biome check --write .",
    "api": "rm -rf src/api && openapi-generator-cli generate -g typescript-axios --remove-operation-id-prefix --additional-properties=modelPropertyNaming=original,fileNaming=camelCase,useSingleRequestParameter=true,withSeparateModelsAndApi=true,supportsES6=true,enablePostProcessFile=true,apiPackage=api,modelPackage=api -o src -i ",
    "release:npm": "npm publish dist",
    "release:preflight": "npm pack ./dist --dry-run",
    "prepare": "husky"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "peerDependencies": {
    "axios": "1.15.2",
    "ee-ts": "1.0.2"
  },
  "dependencies": {
    "deep-copy": "1.4.2",
    "ee-ts": "1.0.2",
    "jssip": "3.13.8",
    "query-string": "9.4.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@openapitools/openapi-generator-cli": "2.39.0",
    "@types/jest": "30.0.0",
    "@types/node": "22.20.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-watch-typeahead": "3.0.1",
    "lint-staged": "17.0.8",
    "ts-jest": "29.4.11",
    "tsdown": "0.22.3",
    "typedoc": "0.28.19",
    "typedoc-github-theme": "0.4.0",
    "typescript": "5.9.3"
  }
}
