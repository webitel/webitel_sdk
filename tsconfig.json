{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es6",
    "lib": ["dom", "es2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist/types",
    "allowJs": true,
    "stripInternal": true,
    "outDir": "dist/esm5",
    "resolveJsonModule": true,
    "importHelpers": true
  },
  "include": ["./src"],
  "compileOnSave": false
}
